# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long, random string in production!
JWT_SECRET=skillforge_super_secret_key_change_in_prod

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# For contact form email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=admin@skillforge.club
